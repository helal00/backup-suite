[Unit]
Description=Backup Suite database size monitor
After=network-online.target
Wants=network-online.target
OnFailure=backup-suite-notify@%n.service

[Service]
Type=forking
__USER_GROUP_DIRECTIVES__
Environment=BACKUP_SUITE_CONFIG_DIR=__CONFIG_DIR__
RuntimeDirectory=backup-suite
PIDFile=%t/backup-suite/database-size-check.pid
ExecStart=__INSTALL_DIR__/bin/systemd-fork-run.sh %t/backup-suite/database-size-check.pid /usr/bin/flock -n __LOCK_FILE__ __INSTALL_DIR__/bin/database-size-check.sh
SuccessExitStatus=SIGTERM
TimeoutStartSec=infinity
StandardOutput=journal
StandardError=journal
SyslogIdentifier=backup-db-monitor
