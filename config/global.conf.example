## Example configuration for public use.
## Copy this file to global.conf and update the values for your own host.

INSTALL_MODE="auto"

SYSTEM_INSTALL_DIR="/opt/backup-suite"
SYSTEM_CANONICAL_SOURCE_DIR="/opt/backup-suite-src"
SYSTEM_CONFIG_DIR="/etc/backup-suite"
SYSTEM_STATE_DIR="/var/lib/backup-suite"
SYSTEM_DB_LOCAL_OUTPUT_DIR="/var/backups/backup-suite/databases"
SYSTEM_RCLONE_CONFIG_PATH="/etc/backup-suite/rclone.conf"
SYSTEM_RCLONE_BIN="rclone"
SYSTEM_FILE_SOURCE_CONFIG_PATH="/etc/backup-suite/file-sources.conf"
SYSTEM_DATABASE_BACKUP_CONFIG_PATH="/etc/backup-suite/database-backups.conf"
SYSTEM_MYSQL_PROFILE_DIR="/etc/backup-suite/mysql-profiles"
SYSTEM_SYSTEMD_UNIT_DIR="/etc/systemd/system"

USER_INSTALL_DIR="$HOME/.local/share/backup-suite"
USER_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/backup-suite"
USER_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/backup-suite"
USER_DB_LOCAL_OUTPUT_DIR="$HOME/backups/backup-suite/databases"
USER_RCLONE_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/backup-suite/rclone.conf"
USER_RCLONE_BIN="rclone"
USER_FILE_SOURCE_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/backup-suite/file-sources.conf"
USER_DATABASE_BACKUP_CONFIG_PATH="${XDG_CONFIG_HOME:-$HOME/.config}/backup-suite/database-backups.conf"
USER_MYSQL_PROFILE_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/backup-suite/mysql-profiles"

RCLONE_REMOTE_ROOT="gdrive,root_folder_id=REPLACE_ME:server-backups"
INCLUDE_HOSTNAME_IN_REMOTE="1"
REMOTE_HOSTNAME=""

FILE_DEFAULT_DESTINATION_ROOT="files"
FILE_ARCHIVE_FOLDER_NAME="deleted_files"
FILE_ARCHIVE_SUFFIX="_old"
FILE_RETENTION_DAYS="21d"
FILE_SYNC_STOP_FILE=".nosync"
FILE_PROJECT_EXCLUDE_FILENAME=".backup-excludes"
FILE_PROCESS_CHECK_ENABLED="1"
FILE_PROCESS_CHECK_USER_ONLY="1"
FILE_PROCESS_CHECK_PATTERNS="vscode-server"
FILE_RCLONE_TRANSFERS="12"
FILE_RCLONE_CHECKERS="24"
FILE_RCLONE_BUFFER_SIZE="128M"
FILE_RCLONE_TPSLIMIT="10"
FILE_RCLONE_EXTRA_FLAGS=""
FILE_BACKUP_ONCALENDAR="*:0/30"

DB_REMOTE_DESTINATION_ROOT="databases"
DB_RETENTION_DAYS="14"
DB_RCLONE_TRANSFERS="4"
DB_RCLONE_CHECKERS="8"
DB_RCLONE_EXTRA_FLAGS=""
DB_SKIP_UNCHANGED_BACKUPS="1"
DB_KEEP_LOCAL_AFTER_UPLOAD="1"
DB_BACKUP_ONCALENDAR="daily"
DB_MONITOR_THRESHOLD_MB="512"
DB_MONITOR_ONCALENDAR="daily"

NOTIFY_FAILURES_ENABLED="0"
NOTIFY_NTFY_TOPIC_URL=""
NOTIFY_NTFY_TITLE_PREFIX="Backup Suite"
NOTIFY_NTFY_PRIORITY="high"
NOTIFY_JOURNAL_LINES="40"

INSTALL_SYSTEMD_UNITS="1"
ENABLE_TIMERS_AFTER_INSTALL="0"
